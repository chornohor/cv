{
  "name": "designer-cv",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm-run-all build:html build:css",
    "build:html": "eleventy",
    "build:css": "sass src/styles/main.scss:_site/styles.css --no-source-map",
    "dev": "npm-run-all build:css --parallel watch:css watch:html",
    "format": "prettier --write \"src/**/*.{njk,scss,json}\" \"*.{js,json}\"",
    "watch:html": "eleventy --serve --port=8080",
    "watch:css": "sass src/styles/main.scss:_site/styles.css --watch --no-source-map"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@fontsource/epilogue": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "modern-normalize": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.3",
    "prettier-plugin-jinja-template": "^2.2.0",
    "sass": "^1.101.0"
  }
}
