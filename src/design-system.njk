<section class="section section--42-100-0-72">
	<h2 class="ta-c">Design Principles</h2>
	<p class="design-principles-text">The system was built around several core principles.</p>
	<div class="design-principles scrollbar-hidden-x">
		<div class="design-principles-item">
			<div class="design-principles-item__number">01</div>
			<div class="design-principles-item__title">Consistency</div>
			<div class="design-principles-item__text">Create predictable and <br>familiar user experiences <br>across products.</div>
		</div>
		<div class="design-principles-item">
			<div class="design-principles-item__number">02</div>
			<div class="design-principles-item__title">Scalability</div>
			<div class="design-principles-item__text">Support future growth <br>without increasing <br>complexity.</div>
		</div>
		<div class="design-principles-item design-principles-item--active">
			<div class="design-principles-item__number">03</div>
			<div class="design-principles-item__title">Reusability</div>
			<div class="design-principles-item__text">Reduce repetitive <br>work with shared <br>components.</div>
		</div>
		<div class="design-principles-item">
			<div class="design-principles-item__number">04</div>
			<div class="design-principles-item__title">Accessibility</div>
			<div class="design-principles-item__text">Ensure components <br>remain clear, usable, <br>and inclusive.</div>
		</div>
		<div class="design-principles-item">
			<div class="design-principles-item__number">05</div>
			<div class="design-principles-item__title">Collaboration</div>
			<div class="design-principles-item__text">Create a shared language <br>between design and <br>engineering teams.</div>
		</div>
	</div>
</section>
