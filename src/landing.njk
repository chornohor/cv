{% for section in landingSections %}
	<section class="section section--24-60-0-72">
		<div class="landings-title">
			<div>
				<small>{{ section.eyebrow }}</small>
				<h1>{{ section.title }}</h1>
			</div>
			<a class="landings-link" href="{{section.url}}" target="_blank">
				<img src="/assets/img/icons/arrow-up.svg" alt="Open landing page prototype">
			</a>
		</div>

		<img class="landings-image" src="{{ section.image }}" alt="{{ section.title }} landing page preview">
		<div class="landings-3-col-info">
			{% for item in section.info %}
				<div>
					<h2>{{ item.title }}</h2>
					<p>{{ item.text }}</p>
				</div>
			{% endfor %}
		</div>
	</section>
{% endfor %}
