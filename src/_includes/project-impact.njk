{% macro projectImpact(impact) %}
	<section class="section section--42-42-0-72">
		<h2>Impact & Contribution</h2>
		<div class="impact-block scrollbar-hidden-x">
			<div id="impact1" class="impact-block--mutted">
				<div class="impact-block__number">1</div>
				<div class="impact-block__title">Team</div>
				<ul class="impact-block__list">
					{% for item in impact.team %}
						<li>{{ item }}</li>
					{% endfor %}
				</ul>
			</div>
			<div id="impact2" class="impact-block--mutted">
				<div class="impact-block__number">2</div>
				<div class="impact-block__title">Responsibilities</div>
				<ul class="impact-block__list">
					{% for item in impact.responsibilities %}
						<li>{{ item }}</li>
					{% endfor %}
				</ul>
			</div>
			<div id="impact3" class="impact-block--mutted">
				<div class="impact-block__number">3</div>
				<div class="impact-block__title">Results</div>
				<ul class="impact-block__list">
					{% for item in impact.results %}
						<li>{{ item }}</li>
					{% endfor %}
				</ul>
			</div>
		</div>
	</section>
{% endmacro %}
